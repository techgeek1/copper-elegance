	"semanticHighlighting": true,
	"semanticTokenColors": {
		// Types - textmate can't reliably detect these in Rust
		"type": "#98a880",
		"class": "#98a880",
		"struct": "#98a880",
		"enum": "#98a880",
		"interface": "#98a880",
		"typeAlias": "#98a880",
		"builtinType": "#98a880",
		"typeParameter": { "foreground": "#98a880", "fontStyle": "italic" },
		// Other niceties textmate can't reliably detect
		"parameter": "#a08870",
		"lifetime": { "foreground": "#a88898", "fontStyle": "italic" },
		"macro": "#c8a870",
		"enumMember": "#d0a868",
		"formatSpecifier": "#d0a868",
		"escapeSequence": "#d0a868",
		// Attributes - catch-all so RA can't override textmate
		"*.attribute": "#c8875c",
		"attributeBracket": "#c8875c",
		"derive": "#98a880",
		"deriveHelper": "#c8875c",
		// Language server only
		"unresolvedReference": "#c8c3bb"
	},
	"tokenColors": [
		{
			"scope": "emphasis",
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"scope": "strong",
			"settings": {
				"fontStyle": "bold"
			}
		},
		{
			"name": "Comment",
			"scope": "comment",
			"settings": {
				"foreground": "#706a64",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Constant Character",
			"scope": "constant.character",
			"settings": {
				"foreground": "#d0a868"
			}
		},
		{
			"name": "Constant Character Escape",
			"scope": "constant.character.escape",
			"settings": {
				"foreground": "#d0a868"
			}
		},
		{
			"name": "Constant Language",
			"scope": "constant.language",
			"settings": {
				"foreground": "#8898a8"
			}
		},
		{
			"name": "Constant Numeric",
			"scope": "constant.numeric",
			"settings": {
				"foreground": "#b87068"
			}
		},
		{
			"name": "Constant Regexp",
			"scope": "constant.regexp",
			"settings": {
				"foreground": "#d0a868"
			}
		},
		{
			"name": "Entity Name Class/Type",
			"scope": [
				"entity.name.type",
				"entity.name.class"
			],
			"settings": {
				"foreground": "#98a880"
			}
		},
		{
			"name": "Primitive/Builtin Type",
			"scope": [
				"storage.type.primitive",
				"support.type.primitive",
				"entity.name.type.primitive"
			],
			"settings": {
				"foreground": "#98a880"
			}
		},
		{
			"name": "Entity Name Function",
			"scope": "entity.name.function",
			"settings": {
				"foreground": "#c8a870"
			}
		},
		{
			"name": "Entity Name Tag",
			"scope": "entity.name.tag",
			"settings": {
				"foreground": "#8898a8"
			}
		},
		{
			"name": "Entity Other Attribute Name",
			"scope": "entity.other.attribute-name",
			"settings": {
				"foreground": "#98a880"
			}
		},
		{
			"name": "Entity Other Inherited Class",
			"scope": "entity.other.inherited-class",
			"settings": {
				"fontStyle": "bold",
				"foreground": "#98a880"
			}
		},
		{
			"name": "Invalid Deprecated",
			"scope": "invalid.deprecated",
			"settings": {
				"foreground": "#c8c3bb"
			}
		},
		{
			"name": "Invalid Illegal",
			"scope": "invalid.illegal",
			"settings": {
				"foreground": "#c8c3bb"
			}
		},
		{
			"name": "Keyword",
			"scope": "keyword",
			"settings": {
				"foreground": "#8898a8"
			}
		},
		{
			"name": "Keyword Operator",
			"scope": "keyword.operator",
			"settings": {
				"foreground": "#8898a8"
			}
		},
		{
			"name": "Keyword Other New",
			"scope": "keyword.other.new",
			"settings": {
				"foreground": "#8898a8"
			}
		},
		{
			"name": "Markup Bold",
			"scope": "markup.bold",
			"settings": {
				"fontStyle": "bold"
			}
		},
		{
			"name": "Markup Changed",
			"scope": "markup.changed",
			"settings": {
				"foreground": "#d0a868"
			}
		},
		{
			"name": "Markup Deleted",
			"scope": "markup.deleted",
			"settings": {
				"foreground": "#b87068"
			}
		},
		{
			"name": "Markup Inserted",
			"scope": "markup.inserted",
			"settings": {
				"foreground": "#90b898"
			}
		},
		{
			"name": "Meta Preprocessor",
			"scope": "meta.preprocessor",
			"settings": {
				"foreground": "#907858"
			}
		},
		{
			"name": "Punctuation",
			"scope": "punctuation",
			"settings": {
				"foreground": "#d4d0c8"
			}
		},
		{
			"name": "Punctuation Definition Parameters",
			"scope": [
				"punctuation.definition.method-parameters",
				"punctuation.definition.function-parameters",
				"punctuation.definition.parameters"
