	"semanticHighlighting": true,
	"semanticTokenColors": {
		// Types - textmate can't reliably detect these in Rust
		"type": "#187058",
		"class": "#187058",
		"struct": "#187058",
		"enum": "#187058",
		"interface": "#187058",
		"typeAlias": "#187058",
		"builtinType": "#187058",
		"typeParameter": { "foreground": "#187058", "fontStyle": "italic" },
		// Other niceties textmate can't reliably detect
		"parameter": "#6a5028",
		"lifetime": { "foreground": "#7a3858", "fontStyle": "italic" },
		"macro": "#855210",
		"enumMember": "#886018",
		"formatSpecifier": "#886018",
		"escapeSequence": "#886018",
		// Attributes - catch-all so RA can't override textmate
		"*.attribute": "#984c10",
		"attributeBracket": "#984c10",
		"derive": "#187058",
		"deriveHelper": "#984c10",
		// Language server only — let textmate handle unresolved references
		//"unresolvedReference": "#2a2520"
	},
	"tokenColors": [
		{
			"scope": "emphasis",
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"scope": "strong",
			"settings": {
				"fontStyle": "bold"
			}
		},
		{
			"name": "Comment",
			"scope": "comment",
			"settings": {
				"foreground": "#8a8278",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Constant Character",
			"scope": "constant.character",
			"settings": {
				"foreground": "#886018"
			}
		},
		{
			"name": "Constant Character Escape",
			"scope": "constant.character.escape",
			"settings": {
				"foreground": "#886018"
			}
		},
		{
			"name": "Constant Language",
			"scope": "constant.language",
			"settings": {
				"foreground": "#345878"
			}
		},
		{
			"name": "Constant Numeric",
			"scope": "constant.numeric",
			"settings": {
				"foreground": "#a0382c"
			}
		},
		{
			"name": "Constant Regexp",
			"scope": "constant.regexp",
			"settings": {
				"foreground": "#886018"
			}
		},
		{
			"name": "Entity Name Class/Type",
			"scope": [
				"entity.name.type",
				"entity.name.class"
			],
			"settings": {
				"foreground": "#187058"
			}
		},
		{
			"name": "Primitive/Builtin Type",
			"scope": [
				"storage.type.primitive",
				"support.type.primitive",
				"entity.name.type.primitive"
			],
			"settings": {
				"foreground": "#187058"
			}
		},
		{
			"name": "Entity Name Function",
			"scope": "entity.name.function",
			"settings": {
				"foreground": "#855210"
			}
		},
		{
			"name": "Entity Name Tag",
			"scope": "entity.name.tag",
			"settings": {
				"foreground": "#345878"
			}
		},
		{
			"name": "Entity Other Attribute Name",
			"scope": "entity.other.attribute-name",
			"settings": {
				"foreground": "#187058"
			}
		},
		{
			"name": "Entity Other Inherited Class",
			"scope": "entity.other.inherited-class",
			"settings": {
				"fontStyle": "bold",
				"foreground": "#187058"
			}
		},
		{
			"name": "Invalid Deprecated",
			"scope": "invalid.deprecated",
			"settings": {
				"foreground": "#2a2520"
			}
		},
		{
			"name": "Invalid Illegal",
			"scope": "invalid.illegal",
			"settings": {
				"foreground": "#2a2520"
			}
		},
		{
			"name": "Keyword",
			"scope": "keyword",
			"settings": {
				"foreground": "#345878"
			}
		},
		{
			"name": "Keyword Operator",
			"scope": "keyword.operator",
			"settings": {
				"foreground": "#345878"
			}
		},
		{
			"name": "Keyword Other New",
			"scope": "keyword.other.new",
			"settings": {
				"foreground": "#345878"
			}
		},
		{
			"name": "Markup Bold",
			"scope": "markup.bold",
			"settings": {
				"fontStyle": "bold"
			}
		},
		{
			"name": "Markup Changed",
			"scope": "markup.changed",
			"settings": {
				"foreground": "#886018"
			}
		},
		{
			"name": "Markup Deleted",
			"scope": "markup.deleted",
			"settings": {
				"foreground": "#a0382c"
			}
		},
		{
			"name": "Markup Inserted",
			"scope": "markup.inserted",
			"settings": {
				"foreground": "#1a7028"
			}
		},
		{
			"name": "Meta Preprocessor",
			"scope": "meta.preprocessor",
			"settings": {
				"foreground": "#604020"
			}
		},
		{
			"name": "Punctuation",
			"scope": "punctuation",
			"settings": {
				"foreground": "#3a3530"
			}
		},
		{
			"name": "Punctuation Definition Parameters",
			"scope": [
				"punctuation.definition.method-parameters",
				"punctuation.definition.function-parameters",
				"punctuation.definition.parameters"
			],
			"settings": {
				"foreground": "#3a3530"
			}
		},
		{
			"name": "Punctuation Definition Tag",
			"scope": "punctuation.definition.tag",
			"settings": {
				"foreground": "#345878"
			}
		},
		{
			"name": "Punctuation Definition Comment",
			"scope": [
				"punctuation.definition.comment",
				"punctuation.end.definition.comment",
